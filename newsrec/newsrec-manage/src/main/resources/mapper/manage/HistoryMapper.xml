<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.newsrec.manage.mapper.HistoryMapper">

    <resultMap type="History" id="HistoryResult">
        <result property="historyId"    column="history_id"    />
        <result property="userId"    column="user_id"    />
        <result property="newsId"    column="news_id"    />
        <result property="viewedAt"    column="viewed_at"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
    </resultMap>

    <sql id="selectHistoryVo">
        select history_id, user_id, news_id, viewed_at, remark, create_time, update_time, create_by, update_by from tb_history
    </sql>

    <select id="selectHistoryList" parameterType="History" resultMap="HistoryResult">
        <include refid="selectHistoryVo"/>
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="newsId != null "> and news_id = #{newsId}</if>
        </where>
    </select>


    <select id="selectHistoryByHistoryId" parameterType="Long" resultMap="HistoryResult">
        <include refid="selectHistoryVo"/>
        where history_id = #{historyId}
    </select>

    <select id="selectHistoryVoList" resultType="com.newsrec.manage.domain.vo.HistoryVo">
        select c.*, u.username, n.title, n.img from tb_history c
        left join tb_users u on c.user_id = u.user_id
        left join tb_news n on c.news_id = n.news_id
        <where>
            <if test="userId != null"> and c.user_id = #{userId}</if>
            <if test="newsId != null"> and c.news_id = #{newsId}</if>
            <if test="username != null and username != ''"> and u.username like concat('%', #{username}, '%')</if>
            <if test="title != null and title != ''"> and n.title like concat('%', #{title}, '%')</if>
        </where>
        order by c.create_time desc
    </select>

    <insert id="insertHistory" parameterType="History" useGeneratedKeys="true" keyProperty="historyId">
        insert into tb_history
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="newsId != null">news_id,</if>
            <if test="viewedAt != null">viewed_at,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="newsId != null">#{newsId},</if>
            <if test="viewedAt != null">#{viewedAt},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
         </trim>
    </insert>

    <update id="updateHistory" parameterType="History">
        update tb_history
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="newsId != null">news_id = #{newsId},</if>
            <if test="viewedAt != null">viewed_at = #{viewedAt},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
        </trim>
        where history_id = #{historyId}
    </update>

    <delete id="deleteHistoryByHistoryId" parameterType="Long">
        delete from tb_history where history_id = #{historyId}
    </delete>

    <delete id="deleteHistoryByHistoryIds" parameterType="String">
        delete from tb_history where history_id in
        <foreach item="historyId" collection="array" open="(" separator="," close=")">
            #{historyId}
        </foreach>
    </delete>
</mapper>
