<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.newsrec.manage.mapper.FavoritesMapper">

    <resultMap type="Favorites" id="FavoritesResult">
        <result property="favoriteId"    column="favorite_id"    />
        <result property="userId"    column="user_id"    />
        <result property="newsId"    column="news_id"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
    </resultMap>

    <sql id="selectFavoritesVo">
        select favorite_id, user_id, news_id, remark, create_time, update_time, create_by, update_by from tb_favorites
    </sql>

    <select id="selectFavoritesList" resultType="com.newsrec.manage.domain.Favorites">
        select c.*,n.title, n.img,n.content,nc.category_name AS categoryName from tb_favorites c
        left join tb_news n on c.news_id = n.news_id
        LEFT JOIN tb_news_categories nc ON n.category_id = nc.category_id
        <where>
            <if test="userId != null "> and c.user_id = #{userId}</if>
            <if test="newsId != null "> and c.news_id = #{newsId}</if>
            <if test="title != null and title != ''"> and n.title like concat('%', #{title}, '%')</if>
        </where>
    </select>

    <select id="selectFavoritesByFavoriteId" parameterType="Long" resultMap="FavoritesResult">
        <include refid="selectFavoritesVo"/>
        where favorite_id = #{favoriteId}
    </select>



    <insert id="insertFavorites" parameterType="Favorites" useGeneratedKeys="true" keyProperty="favoriteId">
        insert into tb_favorites
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="newsId != null">news_id,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="newsId != null">#{newsId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
         </trim>
    </insert>

    <update id="updateFavorites" parameterType="Favorites">
        update tb_favorites
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="newsId != null">news_id = #{newsId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
        </trim>
        where favorite_id = #{favoriteId}
    </update>

    <delete id="deleteFavoritesByFavoriteId" parameterType="Long">
        delete from tb_favorites where favorite_id = #{favoriteId}
    </delete>

    <delete id="deleteFavoritesByFavoriteIds" parameterType="String">
        delete from tb_favorites where favorite_id in
        <foreach item="favoriteId" collection="array" open="(" separator="," close=")">
            #{favoriteId}
        </foreach>
    </delete>
</mapper>
