<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.newsrec.manage.mapper.UserPreferencesMapper">

    <resultMap type="UserPreferences" id="UserPreferencesResult">
        <result property="preferenceId"    column="preference_id"    />
        <result property="userId"    column="user_id"    />
        <result property="categoryId"    column="category_id"    />
        <result property="priority"    column="priority"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectUserPreferencesVo">
        select preference_id, user_id, category_id, priority, create_time, update_time from tb_user_preferences
    </sql>

    <select id="selectUserPreferencesList" parameterType="UserPreferences" resultMap="UserPreferencesResult">
        <include refid="selectUserPreferencesVo"/>
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="priority != null "> and priority = #{priority}</if>
        </where>
    </select>

    <select id="selectUserPreferencesByPreferenceId" parameterType="Long" resultMap="UserPreferencesResult">
        <include refid="selectUserPreferencesVo"/>
        where preference_id = #{preferenceId}
    </select>

    <insert id="insertUserPreferences" parameterType="UserPreferences" useGeneratedKeys="true" keyProperty="preferenceId">
        insert into tb_user_preferences
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="priority != null">priority,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="priority != null">#{priority},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateUserPreferences" parameterType="UserPreferences">
        update tb_user_preferences
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where preference_id = #{preferenceId}
    </update>

    <delete id="deleteUserPreferencesByPreferenceId" parameterType="Long">
        delete from tb_user_preferences where preference_id = #{preferenceId}
    </delete>

    <delete id="deleteUserPreferencesByPreferenceIds" parameterType="Long">
        delete from tb_user_preferences where preference_id in
        <foreach item="preferenceId" collection="preferenceIds" open="(" separator="," close=")">
            #{preferenceId}
        </foreach>
    </delete>

    <!-- 根据用户ID获取用户偏好 -->
    <select id="selectUserPreferencesByUserId" parameterType="Long" resultMap="UserPreferencesResult">
        <include refid="selectUserPreferencesVo"/>
        where user_id = #{userId}
    </select>

    <!-- 获取用户浏览过的新闻ID列表 -->
    <select id="selectUserViewedNewsIds" parameterType="Long" resultType="Long">
        select news_id
        from tb_history
        where user_id = #{userId}
        order by viewed_at desc
    </select>

    <!-- 获取用户点赞过的新闻ID列表 -->
    <select id="selectUserLikedNewsIds" parameterType="Long" resultType="Long">
        select news_id
        from tb_likes
        where user_id = #{userId}
        order by create_time desc
    </select>

    <!-- 获取用户收藏过的新闻ID列表 -->
    <select id="selectUserFavoriteNewsIds" parameterType="Long" resultType="Long">
        select news_id
        from tb_favorites
        where user_id = #{userId}
        order by create_time desc
    </select>

    <!-- 获取所有用户ID -->
    <select id="selectAllUserIds" resultType="Long">
        select user_id
        from tb_users
    </select>

    <!-- 根据分类ID获取新闻 -->
    <select id="selectNewsByCategory" resultType="com.newsrec.manage.domain.vo.NewsVo">
        SELECT n.*, u.username AS username, nc.category_name AS categoryName,
               (SELECT COUNT(*) FROM tb_comments WHERE news_id = n.news_id) AS commentCount,
               (SELECT COUNT(*) FROM tb_history WHERE news_id = n.news_id) AS viewCount,
               (SELECT COUNT(*) FROM tb_likes WHERE news_id = n.news_id) AS likeCount,
               (SELECT COUNT(*) FROM tb_favorites WHERE news_id = n.news_id) AS collectCount
        FROM tb_news n
        LEFT JOIN tb_users u ON n.user_id = u.user_id
        LEFT JOIN tb_news_categories nc ON n.category_id = nc.category_id
        WHERE n.category_id = #{categoryId}
        AND n.status = 1
        ORDER BY n.create_time DESC
        LIMIT #{limit}
    </select>
</mapper>
