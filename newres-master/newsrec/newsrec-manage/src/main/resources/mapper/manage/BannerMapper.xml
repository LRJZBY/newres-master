<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.newsrec.manage.mapper.BannerMapper">

    <resultMap type="Banner" id="BannerResult">
        <result property="bannerId"    column="banner_id"    />
        <result property="img"    column="img"    />
        <result property="newsId"    column="news_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectBannerVo">
        select banner_id, img, news_id, create_time, update_time, create_by, update_by, remark from tb_banner
    </sql>

<!--Vo：轮播图对应新闻标题-->
    <select id="selectBannerVoList" resultType="com.newsrec.manage.domain.vo.BannerVo">
        SELECT c.*, n.title AS title FROM tb_banner c LEFT JOIN tb_news n ON c.news_id = n.news_id
        <where>
            <if test="img != null  and img != ''"> AND c.img = #{img}</if>
            <if test="newsId != null "> AND c.news_id = #{newsId}</if> <!-- 使用表别名 c -->
        </where>
        ORDER BY c.banner_id DESC
    </select>

    <select id="selectBannerList" parameterType="Banner" resultMap="BannerResult">
        <include refid="selectBannerVo"/>
        <where>
            <if test="img != null  and img != ''"> and img = #{img}</if>
            <if test="newsId != null "> and news_id = #{newsId}</if>
        </where>
    </select>

    <select id="selectBannerByBannerId" parameterType="Long" resultMap="BannerResult">
        <include refid="selectBannerVo"/>
        where banner_id = #{bannerId}
    </select>

    <insert id="insertBanner" parameterType="Banner" useGeneratedKeys="true" keyProperty="bannerId">
        insert into tb_banner
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="img != null and img != ''">img,</if>
            <if test="newsId != null">news_id,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="img != null and img != ''">#{img},</if>
            <if test="newsId != null">#{newsId},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateBanner" parameterType="Banner">
        update tb_banner
        <trim prefix="SET" suffixOverrides=",">
            <if test="img != null and img != ''">img = #{img},</if>
            <if test="newsId != null">news_id = #{newsId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where banner_id = #{bannerId}
    </update>

    <delete id="deleteBannerByBannerId" parameterType="Long">
        delete from tb_banner where banner_id = #{bannerId}
    </delete>

    <delete id="deleteBannerByBannerIds" parameterType="String">
        delete from tb_banner where banner_id in
        <foreach item="bannerId" collection="array" open="(" separator="," close=")">
            #{bannerId}
        </foreach>
    </delete>
</mapper>
